{
  "name": "exodus",
  "version": "0.24.0",
  "description": "Exodus App",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port 5173\" \"vite build && electrobun dev --watch\"",
    "build": "vite build",
    "build:stable": "vite build && electrobun build --env=stable",
    "icons": "./scripts/generate-icons.sh",
    "typecheck": "vue-tsc --noEmit",
    "test": "bun test --coverage",
    "test:watch": "bun test --watch",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "format:fix": "oxfmt src --write",
    "format:check": "oxfmt src --check",
    "check": "bun run lint && bun run typecheck && bun run format:check && bun test --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/ui": "4.6.1",
    "@vue-flow/background": "1.3.2",
    "@vue-flow/core": "1.48.2",
    "@vue-flow/minimap": "1.5.4",
    "dagre": "0.8.5",
    "drizzle-orm": "0.45.2",
    "electrobun": "1.16.0",
    "tailwindcss": "4.2.2",
    "vue-i18n": "11.1.3",
    "vue-router": "5.0.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@vitejs/plugin-vue": "6.0.5",
    "concurrently": "9.2.1",
    "husky": "9.1.7",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "oxlint-tailwindcss": "0.6.0",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-svg-loader": "5.1.1",
    "vue": "3.5.32",
    "vue-tsc": "3.2.6"
  }
}
