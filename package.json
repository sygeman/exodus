{
  "name": "exodus-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:stable": "turbo run build:stable",
    "check-types": "turbo run check-types",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "quality": "turbo run //#lint //#format",
    "quality:fix": "turbo run //#lint:fix //#format:fix",
    "check": "turbo run check",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@tailwindcss/node": "4.2.2",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "oxlint-tailwindcss": "0.6.1",
    "turbo": "2.9.6"
  },
  "packageManager": "bun@1.3.12"
}
