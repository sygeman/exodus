{
  "name": "exodus",
  "version": "0.41.0",
  "description": "Exodus App",
  "type": "module",
  "scripts": {
    "dev": "electrobun dev --watch",
    "dev:webview": "vite --port 5173",
    "build": "vite build",
    "build:stable": "vite build && electrobun build --env=stable",
    "icons": "./scripts/generate-icons.sh",
    "check-types": "vue-tsc --noEmit",
    "check": "bun run check-types",
    "prepare": "husky && bun scripts/patch-electrobun.js"
  },
  "dependencies": {
    "@exodus/edem-core": "workspace:*",
    "@exodus/edem-data": "workspace:*",
    "@exodus/edem-electrobun": "workspace:*",
    "@exodus/edem-flows": "workspace:*",
    "@exodus/typescript-config": "workspace:*",
    "@nuxt/ui": "4.7.1",
    "@vue-flow/background": "1.3.2",
    "@vue-flow/core": "1.48.2",
    "@vue-flow/minimap": "1.5.4",
    "@vueuse/core": "14.3.0",
    "dagre": "0.8.5",
    "drizzle-orm": "0.45.2",
    "electrobun": "1.18.1",
    "tailwindcss": "4.2.4",
    "vue-i18n": "11.4.0",
    "vue-router": "5.0.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@vitejs/plugin-vue": "6.0.6",
    "husky": "9.1.7",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-svg-loader": "5.1.1",
    "vue": "3.5.33",
    "vue-tsc": "3.2.8"
  }
}
