{
  "extends": "@exodus/typescript-config/tsconfig",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "#build/ui": ["./node_modules/.nuxt-ui/ui"],
      "#build/ui/*": ["./node_modules/.nuxt-ui/ui/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "auto-imports.d.ts",
    "components.d.ts",
    "env.d.ts"
  ],
  "exclude": ["node_modules", "dist", "build", "../../package/dist"]
}
